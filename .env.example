# Copy this file to .env and fill in your actual keys.
# .env is gitignored — never commit it.

# Google Places API key (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_KEY=your_google_api_key_here

# Foursquare v3 key — used by build_activity_heatmap.mjs
FOURSQUARE_KEY_MJS=your_foursquare_v3_key_here

# Foursquare key — used by build_activity_heatmap.py
FOURSQUARE_KEY_PY=your_foursquare_key_here
